#!/bin/sh

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# 디버깅 로그 파일 경로 (문제가 생기면 이 파일을 확인하면 됨)
DEBUG_LOG="husky_debug.log"

# 환경 정보 로깅 (문제가 생기면 로그부터 봐야 하니까!)
echo "\n--- [$(date)] Commit Attempt ---" >> "$DEBUG_LOG"

# 일반적인 커밋 상황이 아니면 종료
if [ -n "$COMMIT_SOURCE" ]; then
  echo ">> Skip: Not a standard commit (Source: $COMMIT_SOURCE)" >> "$DEBUG_LOG"
  exit 0
fi

# Gemini 경로 및 실행 권한 체크
GEMINI_PATH=$(which gemini)
if [ -z "$GEMINI_PATH" ]; then
  PATH=$PATH:/usr/local/bin:/opt/homebrew/bin
  GEMINI_PATH=$(which gemini)
fi

if [ -z "$GEMINI_PATH" ]; then
  echo "❌ 에러: gemini CLI를 찾을 수 없습니다. (PATH 설정을 확인하세요)" >> "$DEBUG_LOG"
  exit 0 # 훅 때문에 커밋이 막히면 안 되니까 0으로 종료
fi

# 스테이징된 변경사항 확인
DIFF=$(git diff --staged)
if [ -z "$DIFF" ]; then 
  echo "⚠️ 스테이징된 변경사항(diff)이 없습니다. 커밋 메시지 생성을 건너뜁니다." >> "$DEBUG_LOG"
  exit 0
fi


if [ -n "$DIFF" ] && [ -n "$GEMINI_PATH" ]; then
  echo "🤖 Gemini가 커밋 메시지 작성중..."
  echo ">> Calling Gemini API..." >> "$DEBUG_LOG"

  # 프롬프트에 간결함과 명사형 종결어미 강제 규칙 추가
  PROMPT="너는 20년 차 시니어 풀스택 개발자야. 아래 변경사항(diff)을 분석해서 GEMINI.md 규칙에 맞는 커밋 메시지만 딱 출력해.

[필수 작성 규칙]
1. 제목은 'type: 핵심 요약' 형태로 작성.
2. 본문은 장황하게 설명하지 말고, 핵심 이유만 1~3줄로 아주 간결하게 작성.
3. 본문의 각 줄은 반드시 '-' 불릿으로 시작할 것.
4. 문장 끝은 반드시 '~함', '~음', '~됨' 등 명사형 종결어미로 끝낼 것 (예: 반영함, 높임, 정리함). '~했습니다', '~해요' 사용 절대 금지.
5. 인사말, 부연 설명, \`\`\` 같은 마크다운 코드블록 기호는 절대 금지.

$DIFF"

#   GENERATED_MSG=$("$GEMINI_PATH" -p "$PROMPT" -o text --yolo 2>/dev/null)
# 💡 2>&1 을 써서 에러 메시지까지 변수에 담음
    GENERATED_MSG=$("$GEMINI_PATH" -p "$PROMPT" -o text --yolo 2>&1)
    EXIT_CODE=$?
  
  if [ $EXIT_CODE -eq 0 ] && [ -n "$GENERATED_MSG" ]; then
    echo "$GENERATED_MSG" > "$COMMIT_MSG_FILE"
    echo "✅ 깔끔한 스타일로 메시지 자동 입력 완료!"
    echo ">> Success: Message generated." >> "$DEBUG_LOG"
  else
    # 에러가 나면 로그 파일에 상세 내용을 남김
    echo "❌ Error: Gemini 호출 실패 (Code: $EXIT_CODE)" >> "$DEBUG_LOG"
    echo ">> API Response/Error: $GENERATED_MSG" >> "$DEBUG_LOG"
  fi
fi

# 최종 방어선: 스크립트 자체는 항상 성공으로 종료 (커밋을 막지 않기 위함)
# exit 0

